  "refresh_pipeline": {
    "daily": [
      "python scripts/extract_daily_report.py --all",
      "python scripts/sync_to_unified_data.py"
    ],
    "weekly": [
      "python scripts/extract_open_issues.py",
      "python scripts/aggregate_weekly_data.py --headless",
      "python scripts/read_excel_manual.py",
      "python scripts/generate_weekly_report.py --headless"
    ],
    "inspection": [
      "python scripts/inspection/test_hcp_api.py (验证API连通性)",
      "python scripts/inspection/run_inspection.py --project {project_id} --auto-only (数据采集)",
      "python scripts/inspection/run_inspection.py --project {project_id} (完整巡检含人工录入)"
